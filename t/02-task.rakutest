use Test;
use lib 'lib', '../LLM_Chat/lib';
use LLM::Data::Inference::Task;
use LLM::Chat::Backend;
use LLM::Chat::Backend::Settings;
use LLM::Chat::Backend::Response;
use LLM::Chat::Conversation::Message;
use UUID::V4;

# --- MockBackend ---

class MockBackend is LLM::Chat::Backend {
	has @.responses;
	has Int $!call-count = 0;

	method chat-completion(
		@messages where all(@messages) ~~ LLM::Chat::Conversation::Message,
		--> LLM::Chat::Backend::Response
	) {
		my Str:D $text = @!responses[$!call-count++ % @!responses.elems];
		my LLM::Chat::Backend::Response $r .= new(:id(uuid-v4()));
		# Emit and complete asynchronously (so tap processes it)
		start {
			$r.emit($text);
			$r.done;
		}
		$r;
	}

	method chat-completion-stream(@messages, --> LLM::Chat::Backend::Response) {
		self.chat-completion(@messages);
	}

	method text-completion(@messages, Bool $c = False, --> LLM::Chat::Backend::Response) {
		self.chat-completion(@messages);
	}

	method text-completion-stream(@messages, Bool $c = False, --> LLM::Chat::Backend::Response) {
		self.chat-completion(@messages);
	}

	method cancel(LLM::Chat::Backend::Response $r) { $r.cancel }
}

sub mock-backend(*@responses --> MockBackend:D) {
	MockBackend.new(
		:@responses,
		:settings(LLM::Chat::Backend::Settings.new),
	);
}

plan 6;

subtest 'Execute with no parser returns raw string' => {
	plan 1;
	my MockBackend $b = mock-backend('Hello, world!');
	my LLM::Data::Inference::Task $task .= new(
		:backend($b), :user-prompt('Say hello'),
	);
	is $task.execute, 'Hello, world!', 'Raw string returned';
};

subtest 'Execute with parser returns parsed result' => {
	plan 1;
	my MockBackend $b = mock-backend('42');
	my LLM::Data::Inference::Task $task .= new(
		:backend($b), :user-prompt('Give me a number'),
		:parser(-> Str $s { $s.Int }),
	);
	is $task.execute, 42, 'Parser applied';
};

subtest 'Parser failure triggers retry' => {
	plan 1;
	# First response fails parse, second succeeds
	my MockBackend $b = mock-backend('bad', '42');
	my Int:D $parse-count = 0;
	my LLM::Data::Inference::Task $task .= new(
		:backend($b), :user-prompt('Number please'),
		:max-retries(3),
		:parser(-> Str $s {
			$parse-count++;
			die "not a number" unless $s ~~ /^\d+$/;
			$s.Int;
		}),
	);
	is $task.execute, 42, 'Retried and got valid result';
};

subtest 'Retries exhausted dies' => {
	plan 1;
	my MockBackend $b = mock-backend('bad', 'also bad', 'still bad');
	my LLM::Data::Inference::Task $task .= new(
		:backend($b), :user-prompt('Never works'),
		:max-retries(3),
		:parser(-> Str $s { die "nope" }),
	);
	dies-ok { $task.execute }, 'Dies after exhausting retries';
};

subtest 'System prompt included' => {
	plan 1;
	my MockBackend $b = mock-backend('ok');
	my LLM::Data::Inference::Task $task .= new(
		:backend($b),
		:system-prompt('You are helpful.'),
		:user-prompt('Hi'),
	);
	lives-ok { $task.execute }, 'System prompt does not cause error';
};

subtest 'Execute returns on first success without extra retries' => {
	plan 1;
	my Int:D $call-count = 0;
	my MockBackend $b = mock-backend('good');
	my LLM::Data::Inference::Task $task .= new(
		:backend($b), :user-prompt('Once is enough'),
		:max-retries(5),
		:parser(-> Str $s { $call-count++; $s }),
	);
	$task.execute;
	is $call-count, 1, 'Parser called only once on success';
};
