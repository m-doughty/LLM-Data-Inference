use Test;
use lib 'lib', '../LLM_Chat/lib';
use LLM::Data::Inference::JSONTask;
use LLM::Chat::Backend;
use LLM::Chat::Backend::Settings;
use LLM::Chat::Backend::Response;
use LLM::Chat::Conversation::Message;
use UUID::V4;

# --- MockBackend (same as task test) ---

class MockBackend is LLM::Chat::Backend {
	has @.responses;
	has Int $!call-count = 0;

	method chat-completion(
		@messages where all(@messages) ~~ LLM::Chat::Conversation::Message,
		--> LLM::Chat::Backend::Response
	) {
		my Str:D $text = @!responses[$!call-count++ % @!responses.elems];
		my LLM::Chat::Backend::Response $r .= new(:id(uuid-v4()));
		start { $r.emit($text); $r.done; }
		$r;
	}

	method chat-completion-stream(@messages, --> LLM::Chat::Backend::Response) { self.chat-completion(@messages) }
	method text-completion(@messages, Bool $c = False, --> LLM::Chat::Backend::Response) { self.chat-completion(@messages) }
	method text-completion-stream(@messages, Bool $c = False, --> LLM::Chat::Backend::Response) { self.chat-completion(@messages) }
	method cancel(LLM::Chat::Backend::Response $r) { $r.cancel }
}

sub mock-backend(*@responses --> MockBackend:D) {
	MockBackend.new(:@responses, :settings(LLM::Chat::Backend::Settings.new));
}

plan 7;

subtest 'Valid JSON parsed correctly' => {
	plan 2;
	my MockBackend $b = mock-backend('{"name":"Alice","age":30}');
	my LLM::Data::Inference::JSONTask $task .= new(
		:backend($b), :user-prompt('Give me JSON'),
	);
	my $result = $task.execute;
	is $result<name>, 'Alice', 'Name parsed';
	is $result<age>, 30, 'Age parsed';
};

subtest 'JSON wrapped in prose extracted' => {
	plan 1;
	my MockBackend $b = mock-backend('Here is the JSON: {"key":"value"} Hope that helps!');
	my LLM::Data::Inference::JSONTask $task .= new(
		:backend($b), :user-prompt('Give me JSON'),
	);
	is $task.execute<key>, 'value', 'JSON extracted from prose';
};

subtest 'Required keys validated' => {
	plan 1;
	my MockBackend $b = mock-backend('{"name":"Alice"}', '{"name":"Bob","age":25}');
	my LLM::Data::Inference::JSONTask $task .= new(
		:backend($b), :user-prompt('Need name and age'),
		:required-keys('name', 'age'),
		:max-retries(3),
	);
	my $result = $task.execute;
	is $result<age>, 25, 'Retried until required keys present';
};

subtest 'Custom validator called' => {
	plan 1;
	my MockBackend $b = mock-backend('{"score":5}', '{"score":15}');
	my LLM::Data::Inference::JSONTask $task .= new(
		:backend($b), :user-prompt('High score'),
		:max-retries(3),
		:validator(-> %h { %h<score> > 10 }),
	);
	is $task.execute<score>, 15, 'Retried until validator passed';
};

subtest 'Invalid JSON triggers retry' => {
	plan 1;
	my MockBackend $b = mock-backend('not json at all', '{"valid":true}');
	my LLM::Data::Inference::JSONTask $task .= new(
		:backend($b), :user-prompt('JSON please'),
		:max-retries(3),
	);
	ok $task.execute<valid>, 'Retried past invalid JSON';
};

subtest 'Array JSON response' => {
	plan 2;
	my MockBackend $b = mock-backend('[1, 2, 3]');
	my LLM::Data::Inference::JSONTask $task .= new(
		:backend($b), :user-prompt('Array'),
	);
	my $result = $task.execute;
	isa-ok $result, Array, 'Array result';
	is $result.elems, 3, 'Three elements';
};

subtest 'All retries fail dies' => {
	plan 1;
	my MockBackend $b = mock-backend('garbage', 'more garbage', 'still garbage');
	my LLM::Data::Inference::JSONTask $task .= new(
		:backend($b), :user-prompt('Never valid'),
		:max-retries(3),
	);
	dies-ok { $task.execute }, 'Dies after all retries fail';
};
